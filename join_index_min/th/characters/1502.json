ills":[],"icon":"icon/skill/1502_rank6.png"}],"skills":[{"id":"150201","name":"Whistlebolt Sings Joy","max_level":10,"element":"Physical","type":"Normal","type_text":"โจมตีปกติ","effect":"Blast","effect_text":"กระจาย","simple_desc":"สร้าง DMG กายภาพเล็กน้อยแก่ศัตรูหนึ่งตัว และสร้าง DMG กายภาพเล็กน้อย แก่ตัวที่อยู่ใกล้เคียงกับเป้าหมาย","desc":"สร้าง DMG กายภาพ #1[i]% ของ ATK ของ Yao Guang แก่ศัตรูที่กำหนดหนึ่งตัว พร้อมกับสร้าง DMG กายภาพ #2[i]% ของ ATK ของ Yao Guang แก่ตัวที่อยู่ใกล้เคียงกับเป้าหมายด้วย อีกทั้งการโจมตีปกติจะฟื้นฟูพลังงาน เพิ่มขึ้นเป็น 30 หน่วย","params":[[0.45,0.15],[0.54,0.18],[0.63,0.21],[0.72,0.24],[0.81,0.27],[0.9,0.3],[0.99,0.33],[1.08,0.36],[1.17,0.39],[1.26,0.42]],"icon":"icon/skill/1502_basic_atk.png"},{"id":"150202","name":"Decalight Unveils All","max_level":15,"element":"","type":"BPSkill","type_text":"สกิลต่อสู้","effect":"Support","effect_text":"สนับสนุน","simple_desc":"สร้างเขตแดน ระดับปิติสุขของเป้าหมายฝ่ายเราทั้งหมด จะเพิ่มขึ้น นอกจากนี้ เมื่อ Yao Guang โจมตีปกติ หรือปล่อยสกิลต่อสู้ จะได้รับ จุดขำขัน","desc":"สร้างเขตแดนเป็นเวลา #1[i] เทิร์น ทุกครั้งที่เริ่มต้นเทิร์นของตัวเอง ระยะเวลาของเขตแดนจะลดลง 1 เทิร์น และขณะที่มีเขตแดนอยู่ ระดับปิติสุขของเป้าหมายฝ่ายเราทั้งหมด จะเพิ่มขึ้น โดยค่าที่เพิ่มขึ้นเท่ากับ #2[f1]% ของระดับปิติสุขของ Yao Guang นอกจากนี้ หลังจาก Yao Guang โจมตีปกติ หรือปล่อยสกิลต่อสู้ จะได้รับ จุดขำขัน #3[i] แต้ม","params":[[3,0.1,3],[3,0.11,3],[3,0.12,3],[3,0.13,3],[3,0.14,3],[3,0.15,3],[3,0.1625,3],[3,0.175,3],[3,0.1875,3],[3,0.2,3],[3,0.21,3],[3,0.22,3],[3,0.23,3],[3,0.24,3],[3,0.25,3]],"icon":"icon/skill/1502_skill.png"},{"id":"150203","name":"Hexagram of Feathered Fortune","max_level":15,"element":"","type":"Ultra","type_text":"ท่าไม้ตาย","effect":"Support","effect_text":"สนับสนุน","simple_desc":"ได้รับ จุดขำขัน และทำให้ Aha ได้รับ 1 เทิร์นเพิ่มเติม ที่มี จุดขำขัน คงที่ทันที และทำให้ การทะลวงความต้านทาน ทุกประเภท ของเป้าหมายฝ่ายเราทั้งหมดเพิ่มขึ้น","desc":"ได้รับ จุดขำขัน #1[i] แต้ม พร้อมกับทำให้ Aha ได้รับ 1 เทิร์นเพิ่มเติม ที่มี จุดขำขัน คงที่ #4[i] แต้มทันที โดยในเทิร์นนี้จะไม่เสีย จุดขำขัน อีกทั้งจะทำให้ การทะลวงความต้านทาน ทุกประเภทของฝ่ายเราทั้งหมดเพิ่มขึ้น #2[f1]% เป็นเวลา #3[i] เทิร์น","params":[[5,0.1,3,20,1],[5,0.11,3,20,1],[5,0.12,3,20,1],[5,0.13,3,20,1],[5,0.14,3,20,1],[5,0.15,3,20,1],[5,0.1625,3,20,1],[5,0.175,3,20,1],[5,0.1875,3,20,1],[5,0.2,3,20,1],[5,0.21,3,20,1],[5,0.22,3,20,1],[5,0.23,3,20,1],[5,0.24,3,20,1],[5,0.25,3,20,1]],"icon":"icon/skill/1502_ultimate.png"},{"id":"150204","name":"Behold Wherever Light Unfolds","max_level":15,"element":"","type":"Talent","type_text":"พรสวรรค์","effect":"Support","effect_text":"สนับสนุน","simple_desc":"เมื่อ Yao Guang มี \"เจ๋งแจ๋ว\" อยู่ หลังจากเป้าหมายฝ่ายเราโจมตีแล้ว จะเกิด \"มั่งมีศรีสุข\" ซึ่งจะสร้าง DMG ปิติสุขเล็กน้อย ในประเภทที่สอดคล้องเพิ่มอีก 1 ครั้ง แก่ตัวที่โจมตีโดน 1 ตัวแบบสุ่มเป้าหมาย หากการโจมตีครั้งนี้เสียแต้มสกิลต่อสู้ เอฟเฟกต์ข้างต้นจะเกิดขึ้นเพิ่มอีก 1 ครั้ง โดยเอฟเฟกต์นี้ จะไม่ถือเป็นการโจมตี 1 ครั้ง","desc":"เมื่อ Yao Guang มี \"เจ๋งแจ๋ว\":\nหลังเป้าหมายฝ่ายเราปล่อยการโจมตีแล้ว จะทำให้เกิดเอฟเฟกต์ \"มั่งมีศรีสุข\" โดยจะสร้าง DMG ปิติสุข ในประเภทที่สอดคล้อง #1[f1]% เพิ่มอีก 1 ครั้ง แก่ตัวที่โจมตีโดน 1 ตัวแบบสุ่มเป้าหมาย หากการโจมตีครั้งนี้เสียแต้มสกิลต่อสู้ จะทำให้เกิดเอฟเฟกต์ \"มั่งมีศรีสุข\" เพิ่มอีก 1 ครั้ง\nเมื่อเกิดเอฟเฟกต์ \"มั่งมีศรีสุข\" หากระดับปิติสุขของผู้โจมตีต่ำกว่า Yao Guang จะใช้ระดับปิติสุขของ Yao Guang มาคำนวณ DMG ปิติสุข ในครั้งนี้\nการเกิดเอฟเฟกต์ \"มั่งมีศรีสุข\" จะไม่ถือเป็นการโจมตี 1 ครั้ง","params":[[0.1],[0.11],[0.12],[0.13],[0.14],[0.15],[0.1625],[0.175],[0.1875],[0.2],[0.21],[0.22],[0.23],[0.24],[0.25]],"icon":"icon/skill/1502_talent.png"},{"id":"150206","name":"Whistlebolt Sings Joy","max_level":1,"element":"Physical","type":"MazeNormal","type_text":"","effect":"MazeAttack","effect_text":"","simple_desc":"หลังจากโจมตีศัตรูและเข้าสู่การต่อสู้ จะลดทอนความทนทานของประเภท ที่สอดคล้องกับศัตรูเป้าหมาย","desc":"หลังจากโจมตีศัตรูและเข้าสู่การต่อสู้ จะลดทอนความทนทานของประเภท ที่สอดคล้องกับศัตรูเป้าหมาย","params":[],"icon":"icon/skill/1502_basic_atk.png"},{"id":"150207","name":"Untethered Glimmer Sails Far","max_level":1,"element":"","type":"Maze","type_text":"เทคนิค","effect":"Support","effect_text":"สนับสนุน","simple_desc":"เมื่อเข้าสู่การต่อสู้ จะเกิดสกิลต่อสู้ 1 ครั้งโดยอัตโนมัติ เมื่อ Yao Guang อยู่ในทีม การทำลายไอเทมที่สามารถทำลายได้ จะได้รับ \"ซองนำโชค\" ทันที","desc":"หลังจากใช้เทคนิคแล้ว เมื่อเริ่มการต่อสู้ครั้งถัดไป จะเกิดสกิลต่อสู้ 1 ครั้งโดยอัตโนมัติ ซึ่งการเกิดในครั้งนี้จะไม่ใช้แต้มสกิลต่อสู้ และเมื่อ Yao Guang อยู่ในทีม การทำลายไอเทมที่สามารถทำลายได้ จะได้รับ \"ซองนำโชค\" ทันที โดยในแต่ละสัปดาห์ตามปฏิทินจริง จะรับได้มากสุดที่ #1[i] ซอง","params":[[8]],"icon":"icon/skill/1502_technique.png"},{"id":"150220","name":"Let Thy Fortune Burst in Flames","max_level":15,"element":"Physical","type":"ElationDamage","type_text":"สกิลปิติสุข","effect":"AoEAttack","effect_text":"โจมตีหมู่","simple_desc":"ศัตรูทั้งหมดได้รับ DMG เพิ่มขึ้น และสร้าง DMG ปิติสุข กายภาพแก่ศัตรูทั้งหมด หลังจากนั้น จะสร้าง DMG ปิติสุข กายภาพเล็กน้อย แก่ศัตรูหนึ่งตัวแบบสุ่มเป้าหมาย","desc":"ศัตรูทั้งหมดจะตกสู่สถานะ \"เสียงกระซิบของดาวร้าย\" เป็นเวลา #4[i] เทิร์น ศัตรูเป้าหมายที่ติดสถานะ \"เสียงกระซิบของดาวร้าย\" จะได้รับ DMG เพิ่มขึ้น #3[f1]% นอกจากนี้ จะสร้าง DMG ปิติสุข กายภาพ #2[i]% แก่ศัตรูทั้งหมด จากนั้นจะสร้าง DMG ปิติสุข กายภาพ #6[i]% แก่ศัตรูหนึ่งตัวแบบสุ่มเป้าหมาย #5[i] ครั้ง","params":[[1,0.5,0.16,3,5,0.1],[1,0.55,0.16,3,5,0.11],[1,0.6,0.16,3,5,0.12],[1,0.65,0.16,3,5,0.13],[1,0.7,0.16,3,5,0.14],[1,0.75,0.16,3,5,0.15],[1,0.8125,0.16,3,5,0.1625],[1,0.875,0.16,3,5,0.175],[1,0.9375,0.16,3,5,0.1875],[1,1,0.16,3,5,0.2],[1,1.05,0.16,3,5,0.21],[1,1.1,0.16,3,5,0.22],[1,1.15,0.16,3,5,0.23],[1,1.2,0.16,3,5,0.24],[1,1.25,0.16,3,5,0.25]],"icon":null}],"skill_trees":[{"id":"1502001","name":"","max_level":6,"desc":"","params":[],"anchor":"Point01","pre_points":[],"level_up_skills":[{"id":"150201","num":1}],"levels":[{"promotion":0,"level":0,"properties":[],"materials":[]},{"promot