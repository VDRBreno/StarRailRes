{"id":"1501","name":"Sparxie","tag":"Sparxie","rarity":5,"path":"Elation","element":"Fire","max_sp":160,"ranks":[{"id":"150101","name":"#ViralMạngXãHội #CôẤyLàAi?","rank":1,"desc":"Khi Thời Khắc Aha kết thúc sẽ nhận được 5 Điểm Hài Hước. Hiện tại cứ sở hữu 1 Điểm Hài Hước, sẽ khiến toàn phe ta tăng 1.5% Xuyên Kháng Toàn Thuộc Tính, tối đa tăng 15%.","materials":[{"id":"11501","num":1}],"level_up_skills":[],"icon":"icon/skill/1501_rank1.png"},{"id":"150102","name":"#CưDânMạngRấtSángSuốt","rank":2,"desc":"Sau khi Thời Khắc Aha kết thúc, Sparxie nhận 1 hiệp thêm và 2 \"Điểm Bạo\". Mỗi khi tiêu hao 1 \"Điểm Bạo\", bản thân tăng 10% Sát Thương Bạo Kích, duy trì 2 hiệp, tối đa cộng dồn 4 tầng.","materials":[{"id":"11501","num":1}],"level_up_skills":[],"icon":"icon/skill/1501_rank2.png"},{"id":"150103","name":"#HãyNhấn #SiêuLiênKếtNhịpTim","rank":3,"desc":"Cấp Chiến Kỹ +2, tối đa không quá cấp 15; Cấp Tấn Công Thường +1, tối đa không quá cấp 10; Cấp Kỹ Năng Vui Vẻ +1, tối đa không quá cấp 15.","materials":[{"id":"11501","num":1}],"level_up_skills":[{"id":"150102","num":2},{"id":"150101","num":1},{"id":"150120","num":1},{"id":"150109","num":2},{"id":"150108","num":1}],"icon":"icon/skill/1501_skill.png"},{"id":"150104","name":"#CựcCuốn #QuảnLýBiểuCảmĐỉnhCao","rank":4,"desc":"Khi thi triển Tuyệt Kỹ sẽ nhận thêm 5 Điểm Hài Hước, khiến Độ Vui Vẻ của bản thân tăng 36%, duy trì 3 hiệp.","materials":[{"id":"11501","num":1}],"level_up_skills":[],"icon":"icon/skill/1501_rank4.png"},{"id":"150105","name":"#ThếGiớiTanVỡ #NăngLượngTíchCực","rank":5,"desc":"Cấp Tuyệt Kỹ +2, tối đa không quá cấp 15; Cấp Thiên Phú +2, tối đa không quá cấp 15; Cấp Kỹ Năng Vui Vẻ +1, tối đa không quá cấp 15.","materials":[{"id":"11501","num":1}],"level_up_skills":[{"id":"150103","num":2},{"id":"150104","num":2},{"id":"150120","num":1}],"icon":"icon/skill/1501_ultimate.png"},{"id":"150106","name":"#Ta-đa #TôiSắpTrởThànhTuyệtBản","rank":6,"desc":"Xuyên Kháng Toàn Thuộc Tính tăng 20%. Kỹ Năng Vui Vẻ mỗi khi tính vào 1 Điểm Hài Hước sẽ tăng 1 lần số lần gây sát thương thêm, tối đa tăng đến 40 lần.","materials":[{"id":"11501","num":1}],"level_up_skills":[],"icon":"icon/skill/1501_rank6.png"}],"skills":[{"id":"150101","name":"Tịt Ngòi Rồi Sao","max_level":10,"element":"Fire","type":"Normal","type_text":"Tấn Công Thường","effect":"SingleAttack","effect_text":"Đánh Đơn","simple_desc":"Gây lượng nhỏ Sát Thương Hỏa cho 1 kẻ địch.","desc":"Gây Sát Thương Hỏa bằng #1[i]% Tấn Công của Sparxie cho 1 kẻ địch chỉ định.","params":[[0.5],[0.6],[0.7],[0.8],[0.9],[1],[1.1],[1.2],[1.3],[1.4]],"icon":"icon/skill/1501_basic_atk.png"},{"id":"150102","name":"Hò Hét! Sparxicle Đang Kết Nối","max_level":15,"element":"","type":"BPSkill","type_text":"Chiến Kỹ","effect":"Enhance","effect_text":"Cường Hóa","simple_desc":"Bắt đầu kết nối livestream, biến Tấn Công Thường thành \"Trăm Hoa Đua Nở, Kẻ Thắng Độc Tôn!\" và phát động 1 lần \"Bẫy Tương Tác\", trong lần sử dụng kỹ năng này có thể phát động nhiều lần \"Bẫy Tương Tác\".","desc":"Bắt đầu kết nối livestream, biến Tấn Công Thường thành \"Trăm Hoa Đua Nở, Kẻ Thắng Độc Tôn!\" và phát động 1 lần \"Bẫy Tương Tác\", trong lần sử dụng kỹ năng này có thể phát động \"Bẫy Tương Tác\" nhiều lần, tối đa phát động #1[i] lần. Thi triển kỹ năng này không được xem là sử dụng Chiến Kỹ.","params":[[20,28,3,7,4],[20,28,3,7,4],[20,28,3,7,4],[20,28,3,7,4],[20,28,3,7,4],[20,28,3,7,4],[20,28,3,7,4],[20,28,3,7,4],[20,28,3,7,4],[20,28,3,7,4],[20,28,3,7,4],[20,28,3,7,4],[20,28,3,7,4],[20,28,3,7,4],[20,28,3,7,4]],"icon":"icon/skill/1501_skill.png"},{"id":"150103","name":"Vui Quẩy Hết Mức, Quay Hình Hết Mình","max_level":15,"element":"Fire","type":"Ultra","type_text":"Tuyệt Kỹ","effect":"AoEAttack","effect_text":"Đánh Lan","simple_desc":"Nhận Điểm Hài Hước. Gây Sát Thương Hỏa cho toàn bộ phe địch.","desc":"Nhận #1[i] Điểm Hài Hước. Gây cho toàn bộ phe địch Sát Thương Hỏa bằng (#3[f1] x Độ Vui Vẻ + #2[f1]%) Tấn Công của Sparxie.","params":[[2,0.3,0.6],[2,0.32,0.6],[2,0.34,0.6],[2,0.36,0.6],[2,0.38,0.6],[2,0.4,0.6],[2,0.425,0.6],[2,0.45,0.6],[2,0.475,0.6],[2,0.5,0.6],[2,0.52,0.6],[2,0.54,0.6],[2,0.56,0.6],[2,0.58,0.6],[2,0.6,0.6]],"icon":"icon/skill/1501_ultimate.png"},{"id":"150104","name":"Bàn Tay Sparx Sau Hậu Trường","max_level":15,"element":"","type":"Talent","type_text":"Thiên Phú","effect":"Enhance","effect_text":"Cường Hóa","simple_desc":"Khi Sparxie sở hữu \"Việc Tốt Đáng Thưởng\", thi triển Tấn Công Thường Cường Hóa và Tuyệt Kỹ có thể gây Sát Thương Vui Vẻ thuộc tính Hỏa cho phe địch.","desc":"Khi Sparxie sở hữu \"Việc Tốt Đáng Thưởng\":\nThi triển Tấn Công Thường Cường Hóa có thể gây #3[i]% Sát Thương Vui Vẻ thuộc tính Hỏa cho 1 kẻ địch chỉ định, và gây #4[f1]% Sát Thương Vui Vẻ thuộc tính Hỏa cho mục tiêu lân cận kẻ đó. Đồng thời mỗi khi phát động 1 lần \"Bẫy Tương Tác\", sẽ khiến Tấn Công Thường Cường Hóa trong lúc tấn công gây thêm 1 lần #1[f1]% Sát Thương Vui Vẻ thuộc tính Hỏa cho 1 mục tiêu phe địch bị tấn công ngẫu nhiên.\nThi triển Tuyệt Kỹ có thể gây #2[i]% Sát Thương Vui Vẻ thuộc tính Hỏa cho toàn bộ phe địch.","params":[[0.1,0.24,0.2,0.1],[0.11,0.264,0.22,0.11],[0.12,0.288,0.24,0.12],[0.13,0.312,0.26,0.13],[0.14,0.336,0.28,0.14],[0.15,0.36,0.3,0.15],[0.1625,0.39,0.325,0.1625],[0.175,0.42,0.35,0.175],[0.1875,0.45,0.375,0.1875],[0.2,0.48,0.4,0.2],[0.21,0.504,0.42,0.21],[0.22,0.528,0.44,0.22],[0.23,0.552,0.46,0.23],[0.24,0.576,0.48,0.24],[0.25,0.6,0.5,0.25]],"icon":"icon/skill/1501_talent.png"},{"id":"150106","name":"Tấn Công","max_level":1,"element":"Fire","type":"MazeNormal","type_text":"","effect":"MazeAttack","effect_text":"","simple_desc":"Tấn công kẻ địch, sau khi vào chiến đấu sẽ làm giảm Sức Bền thuộc tính tương ứng của mục tiêu phe địch.","desc":"Tấn công kẻ địch, sau khi vào chiến đấu sẽ làm giảm Sức Bền thuộc tính tương ứng của mục tiêu phe địch.","params":[],"icon":"icon/skill/1501_basic_atk.png"},{"id":"150107","name":"Chuyển Lưu Lượng Thành Lợi Nhuận","max_level":1,"element":"","type":"Maze","type_text":"Bí Kỹ","effect":"Impair","effect_text":"Quấy Nhiễu","simple_desc":"Khiến kẻ địch trong khu vực nhất định rơi vào trạng thái \"Chặn\". Tấn công kẻ địch đang ở trạng thái \"Chặn\", sau khi vào chiến đấu sẽ gây lượng nhỏ Sát Thương Hỏa lên toàn bộ phe địch, hồi Điểm Chiến Kỹ.","desc":"Sau khi dùng Bí Kỹ, khiến kẻ địch trong khu vực nhất định rơi vào trạng thái \"Chặn\" #3[i] giây, kẻ địch rơi vào trạng thái \"Chặn\" không thể phát hiện mục tiêu phe ta.\nNếu chủ động tấn công kẻ địch rơi vào trạng thái \"Chặn\", sau khi vào chiến đấu, sẽ gây Sát Thương Hỏa lên toàn bộ phe địch tương đương #2[i]% Tấn Công của Sparxie, đồng thời hồi #1[i] Điểm Chiến Kỹ cho phe ta.","params":[[2,0.5,10]],"icon":"icon/skill/1501_technique.png"},{"id":"150108","name":"Trăm Hoa Đua Nở, Kẻ Thắng Độc Tôn!","max_level":10,"element":"Fire","type":"Normal","type_text":"Tấn Công Thường","effect":"Blast","effect_text":"Khuếch Tán","simple_desc":"Gây lượng nhỏ Sát Thương Hỏa cho 1 kẻ địch, gây lượng nhỏ Sát Thương Hỏa cho mục tiêu lân cận.","desc":"Tổng kết kết quả kết nối livestream, gây cho 1 kẻ địch chỉ định Sát Thương Hỏa bằng #1[i]% Tấn Công của Sparxie, đồng thời gây cho mục tiêu lân cận kẻ đó Sát Thương Hỏa bằng #2[f1]% Tấn Công của Sparxie.","params":[[0.5,0.25],[0.6,0.3],[0.7,0.35],[0.8,0.4],[0.9,0.45],[1,0.5],[1.1,0.55],[1.2,0.6],[1.3,0.65],[1.4,0.7]],"icon":"icon/skill/1501_basic_atk.png"},{"id":"150109","name":"Bẫy Tương Tác","max_level":15,"element":"","type":"BPSkill","type_text":"Chiến Kỹ","effect":"Enhance","effect_text":"Cường Hóa","simple_desc":"Tăng Bội Số Sát Thương của \"Trăm Hoa Đua Nở, Kẻ Thắng Độc Tôn!\", ngẫu nhiên nhận được một loại quà: \"Quá Cháy\" hoặc \"Đỉnh Của Chóp\".","desc":"Khiến Bội Số Sát Thương của \"Trăm Hoa Đua Nở, Kẻ Thắng Độc Tôn!\" lên 1 kẻ địch chỉ định tăng #4[f1]%, Bội Số Sát Thương lên mục tiêu lân cận kẻ đó tăng #5[f1]%. Đồng thời ngẫu nhiên nhận được một loại quà:\n\"Quá Cháy\": #3[i] Điểm Hài Hước và #1[i] Điểm Chiến Kỹ.\n\"Đỉnh Của Chóp\": #2[i] Điểm Hài Hước.\nThi triển kỹ năng này không được xem là sử dụng Chiến Kỹ.","params":[[2,1,2,0.1,0.05],[2,1,2,0.11,0.055],[2,1,2,0.12,0.06],[2,1,2,0.13,0.065],[2,1,2,0.14,0.07],[2,1,2,0.15,0.075],[2,1,2,0.1625,0.0813],[2,1,2,0.175,0.0875],[2,1,2,0.1875,0.0938],[2,1,2,0.2,0.1],[2,1,2,0.21,0.105],[2,1,2,0.22,0.11],[2,1,2,0.23,0.115],[2,1,2,0.24,0.12],[2,1,2,0.25,0.125]],"icon":"icon/skill/1501_skill.png"},{"id":"150110","name":"Trăm Hoa Đua Nở, Kẻ Thắng Độc Tôn!","max_level":10,"element":"Fire","type":"Normal","type_text":"Tấn Công Thường","effect":"Blast","effect_text":"Khuếch Tán","simple_desc":"","desc":"","params":[[0.5,0.25],[0.6,0.3],[0.7,0.35],[0.8,0.4],[0.9,0.45],[1,0.5],[1.1,0.55],[1.2,0.6],[1.3,0.65],[1.4,0.7]],"icon":"icon/skill/1501_basic_atk.png"},{"id":"150120","name":"Tín Hiệu Quá Tải: Màn Kịch Hay Tái Xuất!","max_level":15,"element":"Fire","type":"ElationDamage","type_text":"Kỹ Năng Vui Vẻ","effect":"AoEAttack","effect_text":"Đánh Lan","simple_desc":"Gây Sát Thương Vui Vẻ thuộc tính Hỏa cho toàn bộ kẻ địch. Sau đó gây lượng nhỏ Sát Thương Vui Vẻ thuộc tính Hỏa cho 1 kẻ địch, nảy bật 20 lần. Nhận \"Điểm Bạo\", có thể khấu trừ tiêu hao Điểm Chiến Kỹ.","desc":"Gây #2[f1]% Sát Thương Vui Vẻ thuộc tính Hỏa cho toàn bộ phe địch, đồng thời gây thêm #3[i] lần sát thương. Mỗi lần sát thương gây #1[f1]% Sát Thương Vui Vẻ thuộc tính Hỏa cho 1 kẻ địch ngẫu nhiên. Khiến Sparxie nhận #4[i] \"Điểm Bạo\", có thể dùng để khấu trừ tiêu hao Điểm Chiến Kỹ của Sparxie. Tiêu hao \"Điểm Bạo\" được xem là tiêu hao Điểm Chiến Kỹ.","params":[[0.125,0.25,20,2],[0.1375,0.275,20,2],[0.15,0.3,20,2],[0.1625,0.325,20,2],[0.175,0.35,20,2],[0.1875,0.375,20,2],[0.2031,0.4062,20,2],[0.2188,0.4375,20,2],[0.2344,0.4688,20,2],[0.25,0.5,20,2],[0.2625,0.525,20,2],[0.275,0.55,20,2],[0.2875,0.575,20,2],[0.3,0.6,20,2],[0.3125,0.625,20,2]],"icon":null}],"skill_trees":[{"id":"1501001","name":"","max_level":6,"desc":"","params":[],"anchor":"Point01","pre_points":[],"level_up_skills":[{"id":"150101","nu