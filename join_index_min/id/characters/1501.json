":[[2,0.3,0.6],[2,0.32,0.6],[2,0.34,0.6],[2,0.36,0.6],[2,0.38,0.6],[2,0.4,0.6],[2,0.425,0.6],[2,0.45,0.6],[2,0.475,0.6],[2,0.5,0.6],[2,0.52,0.6],[2,0.54,0.6],[2,0.56,0.6],[2,0.58,0.6],[2,0.6,0.6]],"icon":"icon/skill/1501_ultimate.png"},{"id":"150104","name":"Sleight of Sparx Hand","max_level":15,"element":"","type":"Talent","type_text":"Talent","effect":"Enhance","effect_text":"Enhance","simple_desc":"Saat Sparxie memiliki \"Certified Banger\", melancarkan Enhanced Basic Attack dan Ultimate dapat mengakibatkan Elation DMG Tipe Fire pada musuh.","desc":"Saat Sparxie memiliki \"Certified Banger\":\nMelancarkan Enhanced Basic Attack dapat mengakibatkan #3[i]% Elation DMG Tipe Fire pada 1 musuh yang ditargetkan dan #4[f1]% Elation DMG Tipe Fire pada target di sekitarnya. Selain itu, setiap melancarkan 1 kali \"Engagement Farming\", serangan Enhanced Basic Attack akan mengakibatkan ekstra 1 kali #1[f1]% Elation DMG Tipe Fire pada 1 target musuh acak yang terkena serangan.\nMelancarkan Ultimate dapat mengakibatkan #2[i]% Elation DMG Tipe Fire pada seluruh musuh.","params":[[0.1,0.24,0.2,0.1],[0.11,0.264,0.22,0.11],[0.12,0.288,0.24,0.12],[0.13,0.312,0.26,0.13],[0.14,0.336,0.28,0.14],[0.15,0.36,0.3,0.15],[0.1625,0.39,0.325,0.1625],[0.175,0.42,0.35,0.175],[0.1875,0.45,0.375,0.1875],[0.2,0.48,0.4,0.2],[0.21,0.504,0.42,0.21],[0.22,0.528,0.44,0.22],[0.23,0.552,0.46,0.23],[0.24,0.576,0.48,0.24],[0.25,0.6,0.5,0.25]],"icon":"icon/skill/1501_talent.png"},{"id":"150106","name":"Attack","max_level":1,"element":"Fire","type":"MazeNormal","type_text":"","effect":"MazeAttack","effect_text":"","simple_desc":"Setelah menyerang musuh dan memasuki pertempuran, mengurangi Toughness target musuh sesuai dengan tipe Toughness-nya.","desc":"Setelah menyerang musuh dan memasuki pertempuran, mengurangi Toughness target musuh sesuai dengan tipe Toughness-nya.","params":[],"icon":"icon/skill/1501_basic_atk.png"},{"id":"150107","name":"Content Monetization","max_level":1,"element":"","type":"Maze","type_text":"Technique","effect":"Impair","effect_text":"Impair","simple_desc":"Membuat musuh dalam area tertentu memasuki status \"Block\". Jika menyerang musuh berstatus \"Block\", maka setelah memasuki pertempuran akan mengakibatkan Fire DMG dalam jumlah kecil pada seluruh musuh, serta memulihkan Poin Skill.","desc":"Setelah menggunakan Technique, membuat musuh dalam area tertentu memasuki status \"Block\" selama #3[i] detik. Musuh berstatus \"Block\" tidak dapat mendeteksi rekan tim.\nJika secara aktif menyerang musuh berstatus \"Block\", maka setelah memasuki pertempuran akan mengakibatkan Fire DMG sebesar #2[i]% ATK Sparxie pada seluruh musuh, serta memulihkan #1[i] Poin Skill untuk rekan tim.","params":[[2,0.5,10]],"icon":"icon/skill/1501_technique.png"},{"id":"150108","name":"Bloom! Winner Takes All","max_level":10,"element":"Fire","type":"Normal","type_text":"Basic ATK","effect":"Blast","effect_text":"Blast","simple_desc":"Mengakibatkan Fire DMG dalam jumlah kecil pada 1 musuh dan Fire DMG dalam jumlah kecil pada target di sekitarnya.","desc":"Memfinalisasi hasil koneksi live streaming, mengakibatkan Fire DMG sebesar #1[i]% ATK Sparxie pada 1 musuh yang ditargetkan dan Fire DMG sebesar #2[f1]% ATK Sparxie pada target di sekitarnya.","params":[[0.5,0.25],[0.6,0.3],[0.7,0.35],[0.8,0.4],[0.9,0.45],[1,0.5],[1.1,0.55],[1.2,0.6],[1.3,0.65],[1.4,0.7]],"icon":"icon/skill/1501_basic_atk.png"},{"id":"150109","name":"Engagement Farming","max_level":15,"element":"","type":"BPSkill","type_text":"Skill","effect":"Enhance","effect_text":"Enhance","simple_desc":"Meningkatkan DMG Multiplier dari \"Bloom! Winner Takes All\" dan secara acak memperoleh satu jenis hadiah: \"Straight Fire\" atau \"Unreal Banger\".","desc":"Meningkatkan #4[f1]% DMG Multiplier dari \"Bloom! Winner Takes All\" terhadap 1 musuh yang ditargetkan, dan #5[f1]% DMG Multiplier dari \"Bloom! Winner Takes All\" terhadap target di sekitarnya. Secara acak memperoleh satu jenis hadiah:\n\"Straight Fire\": #3[i]